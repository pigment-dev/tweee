{
  "manifest_version": 3,
  "name": "PigmentDev Tweee",
  "version": "2.4.0",
  "description": "Adds a bird to the toolbar on X. On a supported tweet or article it turns colored; click it to open the post in your Tweee reader.",
  "homepage_url": "https://github.com/pigment-dev/tweee",
  "icons": {
    "48": "icons/icon-color-48.png",
    "96": "icons/icon-color-96.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*"
  ],
  "action": {
    "default_icon": {
      "48": "icons/icon-gray-48.png",
      "96": "icons/icon-gray-96.png"
    },
    "default_title": "Tweee — open a tweet or article to enable"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
